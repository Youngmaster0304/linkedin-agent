# LinkedIn Credentials (REQUIRED)
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password
LINKEDIN_2FA_SECRET=your-totp-secret-from-authenticator-app

# LLM API Keys (Priority: HF/FLUX > Groq > OpenRouter > Cerebras)
HF_TOKEN=your-huggingface-token-here
GROQ_API_KEY=gsk-your-groq-key
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
CEREBRAS_API_KEY=csk-your-cerebras-key

# Database (default: local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/linkedin_agent.db

# Scheduling
POST_TIME_UTC=10:00
TIMEZONE=Asia/Kolkata
POSTS_PER_WEEK=12

# Content Generation
MAX_POST_LENGTH=280
MIN_POST_LENGTH=150
RESEARCH_DEPTH=deep

# Playwright
HEADLESS=true
BROWSER_TIMEOUT=60000

# Analytics
TRACK_ENGAGEMENT=true
ENGAGEMENT_CHECK_HOURS=24

# Storage
DATA_DIR=./data